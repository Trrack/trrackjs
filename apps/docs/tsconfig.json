{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "baseUrl": ".",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "content/**/*.ts",
    "content/**/*.tsx",
    "content/**/*.md",
    "content/**/*.mdx",
    "content/**/*.js",
    "content/**/*.jsx",
    "*.ts",
    "*.tsx",
    "*.js",
    "*.jsx",
    "next-env.d.ts"
  ],
  "exclude": ["node_modules"]
}
