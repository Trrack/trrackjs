{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "../../dist/out-tsc",
        "module": "esnext",
        "moduleResolution": "bundler",
        "types": ["node"]
    },
    "include": [
        "vite.config.ts",
        "src/**/*.d.ts",
        "src/**/*.spec.ts",
        "src/**/*.spec.tsx",
        "tests/**/*.spec.ts",
        "tests/**/*.spec.tsx",
        "tests/**/*.d.ts"
    ]
}
