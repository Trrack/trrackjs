{
    "name": "@trrack/core",
    "version": "1.4.0",
    "license": "BSD-3-Clause",
    "sideEffects": false,
    "files": ["**/*"],
    "main": "./index.js",
    "module": "./index.mjs",
    "types": "./index.d.ts",
    "scripts": {
        "build": "vite build",
        "typecheck": "tsc --noEmit -p tsconfig.lib.json && tsc --noEmit -p tsconfig.spec.json",
        "test": "vitest",
        "test:ci": "vitest run",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint src --ext .ts",
        "docs": "typedoc"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Trrack/trrackjs.git"
    },
    "dependencies": {
        "fast-json-patch": "^3.1.1",
        "immer": "^9.0.21",
        "tslib": "^2.8.1",
        "uuid": "^11.0.0"
    },
    "devDependencies": {
        "@types/uuid": "^11.0.0"
    },
    "exports": {
        ".": {
            "types": "./index.d.ts",
            "import": "./index.mjs",
            "require": "./index.js"
        }
    }
}
